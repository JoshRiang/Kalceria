# ──────────────────────────────────────────────────────────────
# Monorepo Shared Environment Variables
# Copy this to .env in the ROOT directory
# BOTH backend and frontend will load from this file
# NEVER commit .env to Git
# ──────────────────────────────────────────────────────────────

# ──────────────────────────────────────────
# Backend Environment Variables
# ──────────────────────────────────────────

NODE_ENV=development
VERCEL=0
PORT=4000

# CORS
FRONTEND_URL=http://localhost:3000

# PostgreSQL (Neon)
DATABASE_URL=postgresql://user:password@host:5432/kalceria_db?sslmode=require
# SHADOW_DATABASE_URL=postgresql://user:password@shadow-host:5432/shadow_db?sslmode=require

# Redis (Upstash or local)
REDIS_URL=redis://localhost:6379
# For Upstash TLS: rediss://default:token@host:6379

# Auth
JWT_SECRET=your_256bit_random_secret_here_min_32_chars
JWT_EXPIRES_IN=7d

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=Kalceria <onboarding@resend.dev>

# WhatsApp Admin
WA_ADMIN_NUMBER=62812345678

# ──────────────────────────────────────────
# Frontend Environment Variables
# ──────────────────────────────────────────

# Backend API base URL — MUST have NEXT_PUBLIC_ prefix to be accessible in browser
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Optional: Google Maps API Key
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_api_key_here

# Optional: Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
