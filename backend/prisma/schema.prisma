generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────
enum Gender {
  MALE
  FEMALE
  OTHER
}

enum SocialPlatform {
  WA
  IG
  FB
  NULL
}

enum ServiceType {
  SHOOTING
  HOST_EVENT
  EO
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum ServiceBookingStatus {
  PENDING
  PROCESSED
  CANCELLED
}

enum EventStatus {
  DRAFT
  OPEN
  CLOSED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum CommentType {
  ADVICE
  IDEA
}

enum Role {
  USER
  ADMIN
}

// ─── User ────────────────────────────────────────────────────────────────────
model User {
  id                String          @id @default(uuid())
  name              String
  dob               DateTime
  email             String          @unique
  gender            Gender
  phone             String
  passwordHash      String
  profilePicture    String?
  nickname          String?
  domicileLat       Float
  domicileLng       Float
  isEmailVerified   Boolean         @default(false)
  allowLiveLocation Boolean         @default(false)
  isSentEvent       Boolean         @default(false)
  socialPlatform    SocialPlatform  @default(NULL)
  socialLink        String?
  role              Role            @default(USER)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  miniEvents         MiniEvent[]
  serviceBookings    ServiceBooking[]
  bookings           Booking[]
  broadcast          UserBroadcast?
  eventRegistrations EventRegistration[]
  comments           Comment[]

  @@map("users")
}

// ─── Mini Event ──────────────────────────────────────────────────────────────
model MiniEvent {
  id          String   @id @default(uuid())
  creatorId   String
  title       String
  description String?
  lat         Float
  lng         Float
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  expiresAt   DateTime @db.Timestamptz

  creator User @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@map("mini_events")
}

// ─── Service Booking (EO / Car Shoot) ────────────────────────────────────────
model ServiceBooking {
  id              String               @id @default(uuid())
  requestorId     String
  serviceType     ServiceType
  serviceName     String?
  contactPerson   String?
  whatsapp        String?
  location        String?
  locationString  String
  additionalNotes String?
  status          ServiceBookingStatus @default(PENDING)
  paymentStatus   PaymentStatus        @default(PENDING)
  pdfExported     Boolean              @default(false)
  createdAt       DateTime             @default(now())
  version         Int                  @default(1)

  // ─── Phase 3: Financial & Acceptance fields ──────────────────────────────────
  deploymentArea  String?
  technicalBrief  String?
  totalPrice      Float?

  requestor User                 @relation(fields: [requestorId], references: [id], onDelete: Cascade)
  slots     ServiceBookingSlot[]

  @@map("service_bookings")
}

model ServiceBookingSlot {
  id               String   @id @default(uuid())
  serviceBookingId String
  date             DateTime
  startTime        String
  endTime          String

  serviceBooking ServiceBooking @relation(fields: [serviceBookingId], references: [id], onDelete: Cascade)

  @@map("service_booking_slots")
}

// ─── Booking (Need Us? - Timekeeper) ─────────────────────────────────────────
model Booking {
  id            String        @id @default(uuid())
  userId        String
  serviceType   String        @default("SHOOTING")
  bookingDate   DateTime
  startTime     String
  endTime       String
  totalAmount   Float
  status        BookingStatus @default(PENDING)
  paymentStatus PaymentStatus @default(PENDING)
  pdfExported   Boolean       @default(false)
  createdAt     DateTime      @default(now())
  version       Int           @default(1)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bookings")
}

// ─── Media Post ──────────────────────────────────────────────────────────────
model AuditLog {
  id          String   @id @default(uuid())
  adminEmail  String
  action      String
  details     String?
  createdAt   DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

model MediaPost {
  id          String   @id @default(uuid())
  title       String
  imageUrl    String
  description String?
  viewCount   Int      @default(0)
  likeCount   Int      @default(0)
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("media_posts")
}

// ─── Merch (DB-backed, Admin managed) ────────────────────────────────────────
model Merch {
  id           String   @id @default(uuid())
  name         String
  photoUrl     String
  link         String
  price        Float
  isSoldOut    Boolean  @default(false)
  soldCount    Int      @default(0)    // Cumulative units sold
  totalRevenue Float    @default(0)    // Cumulative revenue (IDR)
  createdAt    DateTime @default(now())
  version      Int      @default(1)

  sales MerchSale[]

  @@map("merch")
}

// ─── Merch Sale Log (one row per sale event) ─────────────────────────────────
model MerchSale {
  id           String   @id @default(uuid())
  merchId      String
  qty          Int
  pricePerUnit Float
  totalAmount  Float
  recordedBy   String   // admin email
  createdAt    DateTime @default(now())

  merch Merch @relation(fields: [merchId], references: [id], onDelete: Cascade)

  @@map("merch_sales")
}

// ─── Event (Admin managed) ───────────────────────────────────────────────────
model Event {
  id              String      @id
  title           String
  description     String?
  displayPhotoUrl String
  location        String?
  regStartTime    DateTime
  regEndTime      DateTime
  sessionOptions  Json
  price           Float
  quota           Int         @default(100)
  status          EventStatus @default(OPEN)
  createdAt       DateTime    @default(now())
  version         Int         @default(1)

  registrations EventRegistration[]

  @@map("events")
}

// ─── Event Registration ───────────────────────────────────────────────────────
model EventRegistration {
  id            String        @id @default(uuid())
  userId        String
  eventId       String
  selectedSession String
  paymentStatus PaymentStatus @default(PENDING)
  pdfExported   Boolean       @default(false)
  createdAt     DateTime      @default(now())
  version       Int           @default(0)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@map("event_registrations")
}

// ─── User Broadcast ──────────────────────────────────────────────────────────
model UserBroadcast {
  id        String   @id @default(uuid())
  userId    String   @unique
  message   String
  expiresAt DateTime @db.Timestamptz
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_broadcasts")
}

// ─── Comment (Landing Page Feedback) ─────────────────────────────────────────
model Comment {
  id        String      @id @default(uuid())
  userId    String?
  username  String?
  content   String
  category  String?     @default("Other")
  type      CommentType
  isPinned  Boolean     @default(false)
  createdAt DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("comments")
}
